{
  "info": {
    "name": "LINE Fusion API 測試集合",
    "description": "提供健康檢查與版本查詢等基礎端點，方便以 Postman 驗證 API 狀態。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "健康檢查",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "health"
          ]
        }
      },
      "response": []
    },
    {
      "name": "查詢版本資訊",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/system/version",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "system",
            "version"
          ]
        }
      },
      "response": []
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": []
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": []
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost"
    }
  ]
}
